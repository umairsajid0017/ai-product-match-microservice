# Server
HOST=0.0.0.0
PORT=8001

# Qdrant (Local Mode)
QDRANT_PATH=qdrant_data
QDRANT_COLLECTION=products

# Image Storage
IMAGE_BASE_PATH=orig_images

# Model
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai

# Search
DEFAULT_TOP_K=10
SIMILARITY_THRESHOLD=0.70

# Security
INTERNAL_API_KEY=change-me-to-a-strong-secret
